# Format BIT<N>=SHORT_NAME : Description (optional)
# Bits 0 - 31 only
#
# Edit ONLY this file, then run generate_errors.py to regenerate
# errors_generated.h and errors_generated.py

BIT0=INIT : Init successful
BIT1=GPS_FAIL : No valid gps fix
BIT2=MAG_FAIL : Cannot connect to the magnetometer
BIT3=GPS_ACC_LOW : Gps accuracy low
BIT4=MAG_ACC_LOW : Magnetometer accuracy low
BIT5=BATT_LOW : Battery voltage low
BIT6=LORA_TIMEOUT
BIT7=WIFI_TIMEOUT
BIT8=MOTOR_FAULT : Motor / ESC fault
BIT9=NO_ROUTE : No route loaded, cannot enable A/P
BIT10=NO_HOME : Home WP not set
BIT11=WATER_LOW : Water ingress sensor detected LOW water level
BIT12=WATER_MID : Water ingress sensor detected MEDIUM water level
BIT13=WATER_HIGH : Water ingress sensor detected HIGH water level
BIT14=HDG_A1 : Heading accuracy 1
BIT15=HDG_A2 : Heading accuracy 2
BIT16=HDG_A3 : Heading accuracy 3
BIT17=BAT_UB : Battery cell voltages unbalanced
